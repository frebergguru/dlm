[Desktop Entry]
Type=Application
Version=1.0
Name=dlm
GenericName=Download Manager
Comment=Segmented download manager with archive.org and yt-dlp support
Exec=dlm-gui %u
Icon=guru.freberg.dlm
Terminal=false
Categories=Network;FileTransfer;
Keywords=download;manager;archive.org;yt-dlp;video;segmented;
MimeType=x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/ftp;x-scheme-handler/ftps;
StartupNotify=true
StartupWMClass=org.dlm.Gui
